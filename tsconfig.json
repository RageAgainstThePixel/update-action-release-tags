{
    "compilerOptions": {
        "target": "es2018",
        "module": "esnext",
        "moduleResolution": "bundler",
        "noImplicitAny": false,
        "removeComments": true,
        "preserveConstEnums": true,
        "sourceMap": true,
        "forceConsistentCasingInFileNames": true,
        "rootDir": "src",
        "outDir": "dist",
        "declaration": false,
        "types": [
            "node"
        ],
    },
    "compileOnSave": true,
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "src/**/*.spec.ts",
    ]
}